# ════════════════════════════════════════════════════════════════════════════
# SMS — Environment Variables
#
# HOW TO USE:
#   cp .env.example .env
#   Then fill in the values below.  NEVER commit .env to git.
#
# GENERATE A SECRET KEY:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sms_user:change_me_strong_password@db:5432/school_sms

# 64-char hex random string — MUST be changed before production
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_use_python3_secrets_token_hex_32

# Set to true to enable the /auth/register endpoint (first-run setup only).
# Disable immediately after creating the first admin user.
REGISTRATION_ENABLED=false

# ── OTP email delivery ─────────────────────────────────────────────────────────
# Gmail example: use an app password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Iqra School Portal
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_INTERVAL_SECONDS=10

# ── Razorpay online fee payments ─────────────────────────────────────────────
# Use test keys while developing. Keep real keys only in .env / hosting secrets.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=change_me_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=change_me_webhook_secret

# ── Parent notifications: WhatsApp primary, SMS fallback ─────────────────────
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_BUSINESS_ACCOUNT_ID=0987654321
WHATSAPP_API_VERSION=v18.0

# Optional SMS fallback via MSG91
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=change_me_msg91_auth_key
MSG91_SENDER_ID=IQRAEM
MSG91_TEMPLATE_ID=change_me_msg91_template_id

AUTO_SEND_PAYMENT_CONFIRMATION=true
AUTO_SEND_FEE_REMINDERS=true
AUTO_SEND_LOW_ATTENDANCE_ALERTS=true
LOW_ATTENDANCE_THRESHOLD_PERCENT=75
PORTAL_PUBLIC_URL=https://iqraschool.in/portal
DEFAULT_BRANCH_ID=1
