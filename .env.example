# ════════════════════════════════════════════════════════════════════════════
# SMS — Environment Variables
#
# HOW TO USE:
#   cp .env.example .env
#   Then fill in the values below.  NEVER commit .env to git.
#
# GENERATE A SECRET KEY:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sms_user:change_me_strong_password@db:5432/school_sms

# 64-char hex random string — MUST be changed before production
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_use_python3_secrets_token_hex_32

# Set to true to enable the /auth/register endpoint (first-run setup only).
# Disable immediately after creating the first admin user.
REGISTRATION_ENABLED=false
