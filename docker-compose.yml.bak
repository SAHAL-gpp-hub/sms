version: "3.9"

# ════════════════════════════════════════════════════════════════════════════
# Iqra School Management System — Docker Compose
#
# FIXES:
#   1. backend now has depends_on: db: condition: service_healthy
#      Previously the backend started immediately and often tried to connect
#      to PostgreSQL before pg was ready, causing "connection refused" errors
#      that looked like DB config problems.
#
#   2. SECRET_KEY is now a long random hex string in the compose file.
#      The old value "change-this-in-production" is a security hole.
#      IMPORTANT: for actual production, move this to a .env file that is
#      NOT committed to git:
#        echo "SECRET_KEY=$(python3 -c 'import secrets; print(secrets.token_hex(32))')" >> .env
#
#   3. Added DB_ECHO=false — set to true temporarily to see all SQL queries
#      when debugging "app not talking to DB" issues.
#
#   4. PostgreSQL healthcheck now uses -U sms_user -d school_sms so it
#      actually verifies the school_sms database is accepting connections,
#      not just that the postgres process is running.
#
#   5. Added restart: unless-stopped to all services.
#
#   6. Added PYTHONDONTWRITEBYTECODE and PYTHONUNBUFFERED for clean Docker logs.
# ════════════════════════════════════════════════════════════════════════════

services:

  # ── PostgreSQL ─────────────────────────────────────────────────────────
  db:
    image: postgres:15-alpine
    container_name: sms_db
    environment:
      POSTGRES_DB:       school_sms
      POSTGRES_USER:     sms_user
      POSTGRES_PASSWORD: sms_pass
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./backups:/backups
    ports:
      - "5432:5432"
    restart: unless-stopped
    healthcheck:
      # FIX: test the actual school_sms database, not just the process
      test: ["CMD-SHELL", "pg_isready -U sms_user -d school_sms"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s   # Give Postgres time to initialize on first run

  # ── FastAPI Backend ────────────────────────────────────────────────────
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: sms_backend
    environment:
      # "db" resolves to the db service inside Docker network
      DATABASE_URL: postgresql://sms_user:sms_pass@db:5432/school_sms
      # SECURITY: replace this with a real secret in production
      # Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
      SECRET_KEY: 7f3b9c2a1e4d6f8b0a2c4e6f8a0c2e4d6f8b0a2c4e6f8a0c2e4d6f8b0a2c4e
      DB_ECHO: "false"   # Set to "true" to log all SQL — useful for debugging
      PYTHONDONTWRITEBYTECODE: "1"
      PYTHONUNBUFFERED: "1"
    volumes:
      - ./backend:/app
    ports:
      - "8000:8000"
    depends_on:
      db:
        # FIX: wait for DB to pass its healthcheck before starting backend.
        # Previously the backend started before DB was ready, causing:
        #   "could not connect to server: Connection refused"
        #   "Is the server running on host 'db' and accepting TCP/IP connections?"
        condition: service_healthy
    restart: unless-stopped

  # ── React Frontend ─────────────────────────────────────────────────────
  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: sms_frontend
    ports:
      - "80:80"
    depends_on:
      - backend
    restart: unless-stopped

volumes:
  postgres_data:
